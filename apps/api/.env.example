DATABASE_URL="postgresql://cssd:cssd_dev_pw@localhost:5432/cssd_db?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"
PORT=3000
NODE_ENV=development
# Firebase Cloud Messaging — leave empty to run with push notifications disabled
# (server logs what it would have sent instead of calling the FCM API).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Comma-separated list of allowed browser origins
# dev: เว้นว่าง = อนุญาตทุก origin ; production: เว้นว่าง = ปฏิเสธ browser ทั้งหมด (ต้องตั้ง!)
CORS_ORIGINS=

# Swagger ใน production ปิดโดย default — เปิดชั่วคราวด้วย ENABLE_SWAGGER=true
ENABLE_SWAGGER=

# รหัสผ่านผู้ใช้ seed — production บังคับตั้ง (>=8 ตัว) ไม่งั้น seed จะ fail
SEED_ADMIN_PASSWORD=
SEED_SUPERVISOR_PASSWORD=
SEED_STAFF_PASSWORD=
