DATABASE_URL="postgresql://cssd:cssd_dev_pw@localhost:5432/cssd_db?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"
PORT=3000
NODE_ENV=development
# Firebase Cloud Messaging — leave empty to run with push notifications disabled
# (server logs what it would have sent instead of calling the FCM API).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Comma-separated list of allowed browser origins (optional; default allows all)
CORS_ORIGINS=
