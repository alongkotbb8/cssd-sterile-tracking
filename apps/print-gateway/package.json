{
  "name": "@cssd/print-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Print Gateway worker — claims print jobs from the CSSD API and sends TSPL to a physical label printer (AI_DEVELOPMENT_GUARDRAILS.md Milestone 2)",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "qrcode": "^1.5.4",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "jsqr": "^1.4.0",
    "ts-jest": "^29.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
