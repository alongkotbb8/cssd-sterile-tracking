# URL ของ CSSD API (ไม่ใช่ URL ของ PWA) — บังคับ https:// ยกเว้น localhost/LAN
# (10.x/192.168.x/172.16-31.x) ไม่งั้น config.ts จะปฏิเสธการสตาร์ท (กัน
# X-Gateway-Key รั่วผ่านสายถ้าส่งเป็น http:// ข้ามอินเทอร์เน็ตจริง)
API_BASE_URL=http://localhost:3000/api/v1

# ได้จากตอน ADMIN ลงทะเบียน gateway ผ่าน POST /print-jobs/gateways
# รูปแบบ {keyId}.{secret} — เก็บเป็นความลับ ห้าม commit ค่าจริงลง repo
GATEWAY_API_KEY=

# ความถี่ poll หางานใหม่ (ms)
POLL_INTERVAL_MS=3000
# ความถี่ heartbeat (ms)
HEARTBEAT_INTERVAL_MS=30000

# ตัวส่งข้อมูลไปเครื่องพิมพ์:
#  "console"   = mock (dev เท่านั้น — ห้ามบน production, config.ts จะปฏิเสธ)
#  "usb_spool" = ส่ง raw TSPL เข้า OS printer queue — สำหรับ Xprinter XP-420B USB
#                (printer-class) ต้องตั้ง PRINTER_QUEUE_NAME
#  "serial"    = ส่งผ่าน virtual COM/serial (ถ้า driver สร้าง COM ให้) ต้องตั้ง PRINTER_SERIAL_PATH
PRINTER_TRANSPORT=console

# เครื่องพิมพ์เป้าหมาย (ข้อมูลอ้างอิง/log)
PRINTER_MODEL=XP-420B

# ── usb_spool ── ชื่อ OS printer queue (RAW) ที่ติดตั้งไว้สำหรับ XP-420B
# posix (mac/linux): ชื่อ CUPS queue (`lpstat -p`) · windows: ชื่อ printer/LPR queue
# ใช้ได้เฉพาะ A-Z a-z 0-9 . _ - (กัน injection)
PRINTER_QUEUE_NAME=CSSD-XP420B-01
# timeout การส่งเข้า queue (ms)
PRINTER_SPOOL_TIMEOUT_MS=15000

# renderer รองรับเฉพาะค่านี้ตอนนี้ (ห้ามเปลี่ยนโดยไม่แก้ layout ใน label-renderer.ts)
PRINTER_DPI=203
LABEL_WIDTH_MM=60
LABEL_HEIGHT_MM=40

# ── serial ── path ของ virtual COM port (เช่น /dev/tty.usbserial-xxxx หรือ COM3)
PRINTER_SERIAL_PATH=
PRINTER_SERIAL_BAUD_RATE=9600

# ตั้งเป็น production เมื่อ deploy จริง — ใช้บังคับ guard ต่างๆ (เช่น ห้าม
# PRINTER_TRANSPORT=console) ปล่อยว่างไว้สำหรับพัฒนา/ทดสอบ
NODE_ENV=development
